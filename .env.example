# OpenAI-compatible API
# For OpenAI:
# OPENAI_BASE_URL=https://api.openai.com
#
# For LiteLLM Proxy:
# OPENAI_BASE_URL=http://localhost:4000
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=replace-with-your-api-key

# Models (summarization models are managed in config.json summarization.models)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_EXPECTED_DIM=3072

# Pipeline paths
SRT_OUTPUT_DIR=./output
SRT_DB_PATH=./lancedb
SRT_MASTER_FILE=./examples/master_file_manifest.example.json

# Local development only: allow HTTP for non-localhost endpoints.
# ALLOW_INSECURE_HTTP=false
